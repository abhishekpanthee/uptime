{
  "name": "backend",
  "version": "1.0.0",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "test": "bun test",
    "seed:status": "bun run scripts/seed-status.ts",
    "seed:status:example": "bun run scripts/seed-status.ts --config scripts/seed-status.config.example.json --reset",
    "migrate": "bun run scripts/migrate.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
