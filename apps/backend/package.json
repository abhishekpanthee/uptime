    "@elysiajs/jwt": "^1.4.0",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.22",
    "ioredis": "^5.6.1",
    "nodemailer": "^7.0.6",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/node": "^25.0.9",
    "@types/nodemailer": "^6.4.17",
    "bun-types": "^1.3.5",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.3.3"
  },
