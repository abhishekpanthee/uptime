{
  "name": "project-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "bun run apps/backend/src/index.ts",
    "dev": "bun run --filter='*' dev",
    "dev:frontend": "bun run --filter=frontend dev",
    "dev:backend": "bun run --filter=backend dev",
    "build": "bun run --filter='*' build",
    "build:frontend": "bun run --filter=frontend build",
    "build:backend": "bun run --filter=backend build",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/.next apps/*/dist packages/*/node_modules"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.3.3"
  }
}
